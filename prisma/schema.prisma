generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  BigInt               @id @default(autoincrement())
  email               String               @unique
  name                String
  avatar              String?
  gender              Gender?
  age                 Int?
  dob                 DateTime?
  preferredMode       ScanningMode         @default(NUTRITION)
  skinType            SkinType?
  skinConcerns        String[]             @default([])
  beautyGoals         String[]             @default([])
  height              Float?
  weight              Float?
  activityLevel       ActivityLevel?
  dietaryPreferences  String[]             @default([])
  allergies           String[]             @default([])
  healthGoals         String[]             @default([])
  provider            AuthProvider         @default(GOOGLE)
  isEmailVerified     Boolean              @default(false)
  isProfileCompleted  Boolean              @default(false)
  isActive            Boolean              @default(true)
  metadata            Json?                @default("{}")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  nutritionLogs       NutritionLog[]
  transformationPlans TransformationPlan[]

  @@index([email])
}

model NutritionLog {
  id             String   @id @default(uuid())
  userId         BigInt
  name           String
  servingSize    String?
  calories       Float
  protein        Float
  carbs          Float
  fats           Float
  fiber          Float?
  sugar          Float?
  sodium         Float?
  cholesterol    Float?
  vitaminA       Float?
  vitaminC       Float?
  vitaminB6      Float?
  iron           Float?
  potassium      Float?
  calcium        Float?
  healthScore    Int?
  imageUrl       Json?
  tags           String[] @default([])
  mealType       MealType @default(SNACK)
  otherNutrients Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model TransformationPlan {
  id             String     @id @default(uuid())
  userId         BigInt
  goal           String
  description    String?
  durationDays   Int
  status         PlanStatus @default(ACTIVE)
  dailyCalories  Int
  proteinGrams   Int
  carbsGrams     Int
  fatsGrams      Int
  assessment     Json
  dietSchedule   Json
  workoutRoutine Json
  guidelines     Json
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum SkinType {
  OILY
  DRY
  COMBINATION
  SENSITIVE
  NORMAL
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum ScanningMode {
  NUTRITION
  BEAUTY
}

enum AuthProvider {
  GOOGLE
  EMAIL
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

enum PlanStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}
